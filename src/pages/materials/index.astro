---
import Layout from '../../layouts/Layout.astro';
import TechLogo from '../../components/TechLogo.astro';
import { categories } from '../../data/materials';
---

<Layout title="Materials | The Ops Desk" description="Reference notes on the cloud and DevOps tools I use day to day.">
  <div class="max-w-5xl mx-auto px-6 pt-14 pb-24 fade-up">
    <p class="flex items-center gap-2 font-mono text-[11px] font-semibold tracking-[0.2em] uppercase text-faint mb-2">
      <span class="text-muted">//</span> materials
    </p>
    <h1 class="font-sans text-4xl sm:text-5xl font-black tracking-[-0.03em]" style="background:linear-gradient(95deg, var(--color-tools), var(--color-about)); -webkit-background-clip:text; background-clip:text; color:transparent">
      DevOps tooling reference
    </h1>
    <p class="mt-4 text-muted leading-relaxed max-w-lg">
      Working notes on the cloud and DevOps tools I use day to day. Click a card for the full service/component breakdown.
    </p>

    <div class="mt-10 flex flex-wrap gap-2 pb-6 border-b-2 border-line" role="tablist">
      {categories.map((cat, i) => (
        <button
          type="button"
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          data-tab={i}
          class="tab-btn shrink-0 whitespace-nowrap font-mono text-[11px] font-semibold tracking-[0.1em] uppercase px-4 py-2 rounded-full border-2 border-line text-faint transition-colors"
        >
          {cat.label}
        </button>
      ))}
    </div>

    <div class="mt-8">
      {categories.map((cat, i) => (
        <div class="tab-panel" data-panel={i} hidden={i !== 0}>
          <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {cat.tools.map((tool) => (
              <li>
                <a
                  href={`/materials/${tool.slug}`}
                  class="card-lift themed group flex h-full items-start gap-4 rounded-2xl border-2 border-line bg-surface p-5"
                  style="--glow:var(--color-tools)"
                >
                  <TechLogo name={tool.logo} class="h-12 w-12 shrink-0" />
                  <div class="min-w-0">
                    <span class="font-extrabold text-ink group-hover:text-accent transition-colors">{tool.name}</span>
                    <p class="text-sm text-muted mt-1 leading-relaxed">{tool.desc}</p>
                    <p class="font-mono text-[10px] text-faint mt-2 group-hover:text-accent transition-colors">
                      {tool.services.reduce((n, g) => n + g.items.length, 0)} services &rarr;
                    </p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <style>
    .tab-btn[aria-selected="true"] {
      color: var(--color-ink);
      border-color: var(--color-tools);
      background: color-mix(in srgb, var(--color-tools) 22%, transparent);
    }
    .tab-btn:not([aria-selected="true"]):hover {
      color: var(--color-ink);
      border-color: var(--color-tools);
    }
  </style>

  <script>
    const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const panels = document.querySelectorAll<HTMLElement>('.tab-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((t) => t.setAttribute('aria-selected', 'false'));
        tab.setAttribute('aria-selected', 'true');
        panels.forEach((panel) => {
          panel.hidden = panel.dataset.panel !== tab.dataset.tab;
        });
      });
    });
  </script>
</Layout>

