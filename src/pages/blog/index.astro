---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => import.meta.env.PROD ? !data.draft : true);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const dateFormat = new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' });
---

<Layout title="Blog | The Ops Desk" description="Notes on cloud architecture, DevOps, and platform engineering.">
  <div class="max-w-5xl mx-auto px-6 pt-14 pb-24 fade-up">
    <p class="flex items-center gap-2 font-mono text-[11px] font-semibold tracking-[0.2em] uppercase text-faint mb-2">
      <span class="text-muted">//</span> blog
    </p>
    <h1 class="font-sans text-4xl sm:text-5xl font-black tracking-[-0.03em]" style="background:linear-gradient(95deg, var(--color-blog), var(--color-about)); -webkit-background-clip:text; background-clip:text; color:transparent">
      Notes &amp; writeups
    </h1>
    <p class="mt-4 text-muted leading-relaxed max-w-lg">
      Cloud architecture, DevOps, and platform engineering — things I've shared on LinkedIn, collected here.
    </p>

    <ul class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <li class="card-lift themed rounded-2xl border-2 border-line bg-surface overflow-hidden h-full" style="--glow:var(--color-blog)">
          <a href={`/blog/${post.id}`} class="flex h-full flex-col">
            <div class="p-6 flex flex-col flex-1">
              <p class="font-mono text-[10px] font-semibold tracking-[0.15em] uppercase text-faint">{post.data.category}</p>
              <h2 class="font-extrabold text-lg text-ink mt-1">{post.data.title}</h2>
              <p class="font-mono text-[11px] text-muted mt-2">{dateFormat.format(post.data.date)}</p>
              <p class="text-sm text-muted mt-4 leading-relaxed">{post.data.description}</p>
              <span class="inline-flex items-center gap-1.5 mt-auto pt-4 font-mono text-[11px] text-muted hover:text-accent transition-colors">
                read more <span aria-hidden="true">&rarr;</span>
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Layout>
