---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => import.meta.env.PROD ? !data.draft : true);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFormat = new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<Layout title={`${post.data.title} | Blog | The Ops Desk`} description={post.data.description}>
  <div class="max-w-3xl mx-auto px-6 pt-14 pb-24 fade-up">
    <a href="/blog" class="inline-flex items-center gap-1.5 font-mono text-[11px] text-muted hover:text-accent transition-colors">
      <span aria-hidden="true">&larr;</span> blog
    </a>

    <p class="font-mono text-[11px] font-semibold tracking-[0.2em] uppercase text-faint mt-6">{post.data.category}</p>
    <h1 class="font-sans text-3xl sm:text-4xl font-black tracking-[-0.03em] text-ink mt-2">{post.data.title}</h1>
    <p class="font-mono text-[11px] text-muted mt-3">{dateFormat.format(post.data.date)}</p>

    {post.data.image && (
      <img src={post.data.image} alt={post.data.title} class="w-full h-auto rounded-2xl border-2 border-line mt-8" />
    )}

    <div class="prose dark:prose-invert max-w-none mt-8 prose-headings:font-sans prose-headings:font-extrabold prose-a:text-accent">
      <Content />
    </div>

    {post.data.tags.length > 0 && (
      <ul class="flex flex-wrap gap-2 mt-10">
        {post.data.tags.map((tag: string) => (
          <li class="font-mono text-[10px] uppercase tracking-[0.1em] text-faint border border-line rounded-full px-3 py-1">{tag}</li>
        ))}
      </ul>
    )}

    {post.data.linkedin && (
      <a href={post.data.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 mt-8 font-mono text-[11px] text-muted hover:text-accent transition-colors">
        view original on linkedin <span aria-hidden="true">&rarr;</span>
      </a>
    )}
  </div>
</Layout>
